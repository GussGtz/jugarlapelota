# Dependencias
node_modules/
backend/node_modules/

# Build
dist/

# Env
.env
.env.local
.env.*.local
backend/.env

# SQLite (solo desarrollo local)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Uploads locales (en prod se usa Cloudinary)
backend/data/uploads/

# Archivos de video grandes (supera límite de GitHub 100MB)
*.mp4
*.mov
*.avi
# Excepción: tutoriales de instalación PWA, livianos (~9MB c/u)
!public/videos/instalar-android.mp4
!public/videos/instalar-apple.mp4

# Sistema
.DS_Store
*.local
.claude/
