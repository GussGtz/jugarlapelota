# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Base de datos (Neon PostgreSQL) ───────────────────────────────
# Obtén este valor desde tu dashboard de Neon > Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/jugarlapelota?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_seguro
JWT_EXPIRES=7d

# ── Cloudinary (para subir imágenes) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ── CORS (URL de tu frontend en Render) ───────────────────────────
FRONTEND_URL=https://tu-frontend.onrender.com

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ── Web Push (VAPID) ──────────────────────────────────────────────
VAPID_SUBJECT=mailto:admin@jugarlapelota.com
PUBLIC_VAPID_KEY=tu_public_vapid_key
PRIVATE_VAPID_KEY=tu_private_vapid_key
